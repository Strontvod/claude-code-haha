# Claude Haha always uses an isolated config/plugins/MCP user dir under ~/.claude-haha.
# Never point CLAUDE_CONFIG_DIR at the official global ~/.claude directory.
# CLAUDE_CONFIG_DIR=C:\Users\YOU\.claude-haha

# --- Primary setup: OpenRouter Qwen 3.6 Plus Free (Anthropic-compatible, free default) ---
# https://openrouter.ai/qwen/qwen3.6-plus:free/api
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=your-openrouter-key
ANTHROPIC_BASE_URL=https://openrouter.ai/api
ANTHROPIC_MODEL=qwen/qwen3.6-plus:free
ANTHROPIC_SMALL_FAST_MODEL=qwen/qwen3.6-plus:free
ANTHROPIC_DEFAULT_SONNET_MODEL=qwen/qwen3.6-plus:free
ANTHROPIC_DEFAULT_HAIKU_MODEL=qwen/qwen3.6-plus:free
ANTHROPIC_DEFAULT_OPUS_MODEL=qwen/qwen3.6-plus:free
CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1
# If your gateway still errors on prompt cache_control blocks, uncomment:
# DISABLE_PROMPT_CACHING=1

# --- Manual alternative: Fireworks AI GLM-5 (Anthropic-compatible, paid API) ---
# https://docs.fireworks.ai/ecosystem/integrations/claude-code
# ANTHROPIC_API_KEY=your-fireworks-key
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=https://api.fireworks.ai/inference
# ANTHROPIC_MODEL=accounts/fireworks/models/glm-5
# ANTHROPIC_SMALL_FAST_MODEL=accounts/fireworks/models/glm-5
# ANTHROPIC_DEFAULT_SONNET_MODEL=accounts/fireworks/models/glm-5
# ANTHROPIC_DEFAULT_HAIKU_MODEL=accounts/fireworks/models/glm-5
# ANTHROPIC_DEFAULT_OPUS_MODEL=accounts/fireworks/models/glm-5
# CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1

# --- Optional fallback: Local Ollama via repo proxy (port 4000) ---
# ANTHROPIC_BASE_URL=http://127.0.0.1:4000
# LOCAL_LLM_UPSTREAM=http://127.0.0.1:11434
# LOCAL_LLM_UPSTREAM_PROVIDER=ollama
# Qwen3.x: proxy defaults to think=false for latency. Set LOCAL_LLM_OLLAMA_THINK=1 for chain-of-thought (slower).
# LOCAL_LLM_OLLAMA_THINK=1
# Default ~12GB VRAM: Qwen3.5 9B — ollama pull qwen3.5:9b (see https://ollama.com/library/qwen3.5 )
# ANTHROPIC_MODEL=qwen3.5:9b
# ANTHROPIC_SMALL_FAST_MODEL=qwen3.5:9b
# ANTHROPIC_DEFAULT_SONNET_MODEL=qwen3.5:9b
# ANTHROPIC_DEFAULT_HAIKU_MODEL=qwen3.5:9b
# ANTHROPIC_DEFAULT_OPUS_MODEL=qwen3.5:9b
# Use API key path (dummy ok for local gateway)
# ANTHROPIC_API_KEY=local-dev-key

# Mock upstream only: set LOCAL_LLM_UPSTREAM=http://127.0.0.1:8080 and provider=openai, then use local-dev-model
API_TIMEOUT_MS=3000000
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
DISABLE_TELEMETRY=1
# Disables client prompt caching (see getPromptCachingEnabled in src/services/api/claude.ts).
# DISABLE_PROMPT_CACHING=1
