#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

official_config_dir="${HOME}/.claude"

# Match PowerShell launcher: isolated config unless CLAUDE_CONFIG_DIR is already set.
if [[ -z "${CLAUDE_CONFIG_DIR:-}" ]]; then
  export CLAUDE_CONFIG_DIR="${HOME}/.claude-haha"
fi

if [[ "${CLAUDE_CONFIG_DIR}" == "${official_config_dir}" ]]; then
  echo "claude-haha must use an isolated config directory under ~/.claude-haha and must not point at the official global ~/.claude directory." >&2
  exit 1
fi

mkdir -p "$CLAUDE_CONFIG_DIR"

# Force recovery CLI (simple readline REPL, no Ink TUI)
if [[ "${CLAUDE_CODE_FORCE_RECOVERY_CLI:-0}" == "1" ]]; then
  exec bun --env-file=.env ./src/localRecoveryCli.ts "$@"
fi

# Default: full CLI with Ink TUI
exec bun --env-file=.env ./src/entrypoints/cli.tsx "$@"
